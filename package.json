{
  "publisher": "SHI-IT",
  "name": "dev-web-helper",
  "displayName": "레거시 웹 통합 개발팩",
  "description": "웹시스템 개발을 위한 VS Code 확장 통합팩",
  "version": "2.0.2",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionDependencies": [
    "vscjava.vscode-java-pack"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dev-web-helper.showSettings",
        "title": "Show Settings Panel",
        "category": "Legacy-Web"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "web-sidebar",
          "title": "레거시 웹 개발환경 관리",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "web-sidebar": [
        {
          "type": "webview",
          "id": "dev-web-helper.settingsView",
          "name": "",
          "contextualTitle": "레거시 웹 개발환경 관리"
        }
      ]
    },
    "configuration": {
      "title": "shi-it-dev-web-env",
      "properties": {
        "shiDevWebHelper.gradlePath": {
          "type": "string",
          "description": "Gradle 경로"
        },
        "shiDevWebHelper.jdkPath": {
          "type": "string",
          "description": "JDK 경로"
        },
        "shiDevWebHelper.tomcatPath": {
          "type": "string",
          "description": "Tomcat 경로"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:all",
    "compile": "tsc -p ./",
    "compile:webview": "cd ui && npm install && npm run build",
    "build:all": "npm run compile && npm run compile:webview",
    "watch": "tsc -watch -p ./",
    "watch:webview": "cd ui && npm run dev",
    "lint": "eslint src --ext ts",
    "test": "jest"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "cpy": "^13.2.1",
    "fs-extra": "^11.3.3",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  }
}
